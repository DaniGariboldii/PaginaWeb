generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  CLIENT
  ADMIN
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
  REJECTED
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  firstName     String
  lastName      String
  email         String   @unique
  passwordHash  String
  phone         String?
  role          Role     @default(CLIENT)
  active        Boolean  @default(true)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cart                    Cart?
  orders                  Order[]
  addresses               Address[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  reviews                 Review[]
  wishlist                WishlistItem[]

  @@map("users")
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique // SHA-256 del token; el token en crudo solo viaja por email
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model Review {
  id        String   @id @default(uuid())
  productId String
  userId    String
  rating    Int // 1 a 5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId]) // una reseña por usuario por producto
  @@map("reviews")
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlist_items")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique // SHA-256 del token; el token en crudo solo viaja por email
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@map("categories")
}

model Brand {
  id        String   @id @default(uuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("brands")
}

model Product {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  description   String?
  price         Decimal  @db.Decimal(10, 2)
  discountPrice Decimal? @db.Decimal(10, 2)
  stock         Int      @default(0)
  active        Boolean  @default(true)
  featured      Boolean  @default(false)
  categoryId    String
  brandId       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category       Category        @relation(fields: [categoryId], references: [id])
  brand          Brand?          @relation(fields: [brandId], references: [id])
  images         ProductImage[]
  cartItems      CartItem[]
  orderItems     OrderItem[]
  stockMovements StockMovement[]
  reviews        Review[]
  wishlistedBy   WishlistItem[]

  @@map("products")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  publicId  String? // Cloudinary public_id for future deletion
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Cart {
  id             String    @id @default(uuid())
  userId         String    @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  reminderSentAt DateTime? // último email de carrito abandonado enviado

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  productId String
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@map("cart_items")
}

model Address {
  id         String   @id @default(uuid())
  userId     String? // null = dirección de un pedido de invitado (no pertenece a una cuenta)
  province   String
  city       String
  postalCode String
  street     String
  number     String
  floor      String?
  apartment  String?
  reference  String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

model Order {
  id            String      @id @default(uuid())
  userId        String? // null = compra como invitado (sin cuenta)
  subtotal      Decimal     @default(0) @db.Decimal(10, 2)
  discount      Decimal     @default(0) @db.Decimal(10, 2)
  shippingCost  Decimal     @default(0) @db.Decimal(10, 2)
  couponCode    String?
  total         Decimal     @db.Decimal(10, 2)
  status        OrderStatus @default(PENDING_PAYMENT)
  addressId     String
  paymentMethod String      @default("mercadopago")
  // Datos de contacto del invitado (cuando userId es null)
  guestEmail    String?
  guestName     String?
  guestPhone    String?
  // Envío
  trackingNumber String? // número de seguimiento que carga el admin al despachar
  carrier        String? // transportista (Correo Argentino, Andreani, etc.)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user    User?       @relation(fields: [userId], references: [id])
  address Address     @relation(fields: [addressId], references: [id])
  items   OrderItem[]
  payment Payment?

  @@map("orders")
}

model ShippingZone {
  id            String   @id @default(uuid())
  name          String
  provinces     String[] // provincias que cubre esta zona
  cost          Decimal  @db.Decimal(10, 2)
  freeThreshold Decimal? @db.Decimal(10, 2) // envío gratis si el subtotal supera este monto
  isDefault     Boolean  @default(false) // zona comodín para provincias no listadas
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("shipping_zones")
}

enum CouponType {
  PERCENTAGE
  FIXED
}

model Coupon {
  id          String     @id @default(uuid())
  code        String     @unique // siempre en mayúsculas
  type        CouponType
  value       Decimal    @db.Decimal(10, 2) // % o monto fijo según type
  minPurchase Decimal?   @db.Decimal(10, 2)
  maxUses     Int? // null = ilimitado
  usedCount   Int        @default(0)
  active      Boolean    @default(true)
  expiresAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("coupons")
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  productId   String? // nullable: soft delete means product may be inactive but not gone
  productName String // snapshot del nombre al momento de compra
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  subtotal    Decimal @db.Decimal(10, 2)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("order_items")
}

model Payment {
  id                   String        @id @default(uuid())
  orderId              String        @unique
  provider             String        @default("mercadopago")
  // ID de la preferencia (Checkout Pro). Se reescribe en cada reintento de checkout,
  // por eso NO es único. Identifica el intento de pago, no el pago concretado.
  providerPreferenceId String?
  // ID del pago concretado en Mercado Pago. Único y global: identifica la transacción real.
  providerPaymentId    String?       @unique
  status               PaymentStatus @default(PENDING)
  amount               Decimal       @db.Decimal(10, 2)
  rawResponse          Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model StockMovement {
  id        String            @id @default(uuid())
  productId String
  type      StockMovementType
  quantity  Int
  reason    String?
  createdAt DateTime          @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@map("stock_movements")
}
