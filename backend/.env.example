# ─── Base de datos ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ecommerce_db"

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# URL pública del backend (producción) — usada por el webhook de Mercado Pago
BACKEND_URL=http://localhost:4000
# Confiar en reverse proxy (nginx/Railway/Render). Auto-activado si NODE_ENV=production
TRUST_PROXY=false

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_REFRESH_SECRET=cambia_esto_por_otro_secreto_largo_y_aleatorio
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS / Cookies ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
# Orígenes permitidos (coma-separados). Si se omite, usa FRONTEND_URL
CORS_ORIGINS=http://localhost:5173
# 'strict' si front y back comparten dominio; 'none' si están en dominios distintos (requiere HTTPS)
COOKIE_SAMESITE=lax

# ─── Mercado Pago ─────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=tu_access_token_de_mercado_pago
# OBLIGATORIO en producción cuando hay MP_ACCESS_TOKEN: sin él el backend no arranca,
# y los webhooks sin firma se rechazan (evita "pagos aprobados" falsos). Se saca del panel de MP.
MP_WEBHOOK_SECRET=tu_secret_para_validar_webhooks
MP_SUCCESS_URL=http://localhost:5173/pago/exitoso
MP_FAILURE_URL=http://localhost:5173/pago/rechazado
MP_PENDING_URL=http://localhost:5173/pago/pendiente

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ─── Email (recuperación de contraseña) ──────────────────────────────────────
# Sin SMTP configurado, en desarrollo se usa Ethereal (loguea una URL de preview).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=MiTienda <no-reply@mitienda.com>
# Email donde la tienda recibe consultas, solicitudes de arrepentimiento y avisos de venta
STORE_EMAIL=hola@mitienda.com

# ─── Seed del admin ───────────────────────────────────────────────────────────
# OBLIGATORIAS en producción: sin ellas el seed no crea el admin (evita una
# contraseña conocida). En desarrollo, si las dejás vacías, se usa admin@mitienda.com / Admin1234.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Horas de inactividad antes de mandar el recordatorio de carrito abandonado
ABANDONED_CART_HOURS=4
