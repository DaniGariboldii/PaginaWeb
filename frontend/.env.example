VITE_API_URL=http://localhost:4000/api
VITE_MP_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# URL pública del sitio (sin barra final). Se usa para canonical/Open Graph en SEO.
VITE_SITE_URL=https://mitienda.com

# Botón flotante de WhatsApp (número internacional sin + ni espacios). Vacío = oculto.
VITE_WHATSAPP_NUMBER=
VITE_WHATSAPP_MESSAGE=Hola! Tengo una consulta sobre la tienda.

# Analytics (opcionales; vacío = no se carga nada)
VITE_GA_ID=               # Google Analytics 4, ej: G-XXXXXXXXXX
VITE_META_PIXEL_ID=       # Meta (Facebook) Pixel, ej: 1234567890
