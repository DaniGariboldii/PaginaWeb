# ─── Variables para docker-compose ──────────────────────────────────────────────
# Copiá este archivo a .env (en la raíz) antes de `docker compose up`.

# Base de datos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia_esta_password
POSTGRES_DB=ecommerce_db

# JWT (generá secretos largos y aleatorios, ej: openssl rand -hex 32)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# URLs públicas (con dominio real en producción)
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:8080
# 'strict' si todo va por el mismo dominio (recomendado con el nginx incluido)
COOKIE_SAMESITE=strict

# Mercado Pago (opcional; sin esto se usa el modo simulado)
MP_ACCESS_TOKEN=
MP_SUCCESS_URL=http://localhost:8080/pago/exitoso
MP_FAILURE_URL=http://localhost:8080/pago/rechazado
MP_PENDING_URL=http://localhost:8080/pago/pendiente

# Cloudinary (opcional; necesario para subir imágenes de productos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
